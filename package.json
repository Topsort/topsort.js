{
  "name": "topsort.js",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/web build",
    "typecheck": "bun run --cwd packages/core typecheck",
    "test": "bun run typecheck && bun run --cwd packages/web test",
    "test:e2e": "bun run --cwd packages/web test:e2e",
    "format": "biome check",
    "format:fix": "biome check --write",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@playwright/test": "1.61.1",
    "@types/bun": "1.3.3",
    "bunup": "0.16.10",
    "lefthook": "2.1.10",
    "msw": "2.12.3",
    "typescript": "6.0.3"
  }
}
