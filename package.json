{
  "name": "topsort.js",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/web build",
    "test": "bun run --cwd packages/web test",
    "test:e2e": "bun run build && playwright test",
    "format": "biome check",
    "format:fix": "biome check --write",
    "prepare": "lefthook install",
    "serve:e2e": "bun run ./e2e/server.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "1.58.0",
    "@types/bun": "1.3.3",
    "bunup": "0.16.10",
    "lefthook": "2.1.6",
    "msw": "2.12.3",
    "typescript": "6.0.2"
  }
}
