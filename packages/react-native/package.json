{
  "name": "@topsort/react-native-sdk",
  "version": "0.5.0",
  "description": "The official Topsort SDK for React Native",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "author": "Márcio Barbosa <marcio@topsort.com>",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Topsort/topsort.js",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/Topsort/topsort.js/issues"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist/index.d.cts",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/index.cjs",
    "package.json"
  ],
  "scripts": {
    "build": "bunup",
    "test": "bun test",
    "test:harness": "bun run build && bun test ./harness/smoke.test.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@topsort/sdk-core": "workspace:*",
    "react-native-url-polyfill": "^2.0.0"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.17.0",
    "@react-native-community/netinfo": ">=9.0.0",
    "react-native": ">=0.70.0",
    "react-native-mmkv": ">=2.0.0",
    "react-native-url-polyfill": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    },
    "react-native-mmkv": {
      "optional": true
    }
  },
  "keywords": [
    "topsort",
    "sdk",
    "react-native",
    "typescript",
    "offline"
  ]
}
