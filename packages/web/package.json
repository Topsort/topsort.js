{
  "name": "@topsort/sdk",
  "version": "0.4.1",
  "description": "The official Topsort SDK for TypeScript and JavaScript",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "author": "Márcio Barbosa <marcio@topsort.com>",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Topsort/topsort.js",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/Topsort/topsort.js/issues"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist/index.d.cts",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/index.cjs",
    "package.json"
  ],
  "scripts": {
    "build": "bunup",
    "test": "bun test",
    "test:e2e": "bun run build && playwright test",
    "serve:e2e": "bun run ./e2e/server.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@topsort/sdk-core": "workspace:*"
  },
  "keywords": [
    "topsort",
    "sdk",
    "javascript",
    "typescript"
  ]
}
