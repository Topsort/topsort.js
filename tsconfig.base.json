{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ES2020",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "downlevelIteration": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "allowJs": true,
    "types": ["bun"]
  }
}
